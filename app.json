{
  "expo": {
    "name": "WeatherAI",
    "slug": "weather-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "weatherai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0066cc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weatherai.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow WeatherAI to use your location to provide accurate weather data and nearby place recommendations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0066cc",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.weatherai.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "INTERNET",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow WeatherAI to use your location to provide accurate weather data and nearby place recommendations."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "db69eca2-2887-4cec-aec7-f9ab34634771"
      },
      "EXPO_PUBLIC_OPENWEATHER_API_KEY": "$EXPO_PUBLIC_OPENWEATHER_API_KEY",
      "EXPO_PUBLIC_FOURSQUARE_API_KEY": "$EXPO_PUBLIC_FOURSQUARE_API_KEY"
    },
    "owner": "edoman2003"
  }
}